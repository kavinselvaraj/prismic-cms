{
  "id": "content_page",
  "label": "Content Page",
  "format": "custom",
  "repeatable": true,
  "status": true,
  "json": {
    "Main": {
      "uid": {
        "type": "UID",
        "config": {
          "label": "UID"
        }
      },
      "page_kind": {
        "type": "Select",
        "config": {
          "label": "Page Kind",
          "options": [
            "faq_landing",
            "faq_category",
            "faq_detail"
          ]
        }
      },
      "title": {
        "type": "Text",
        "config": {
          "label": "Title"
        }
      },
      "description": {
        "type": "StructuredText",
        "config": {
          "label": "Description",
          "single": "paragraph,strong,em,hyperlink"
        }
      },
      "eyebrow": {
        "type": "Text",
        "config": {
          "label": "Eyebrow"
        }
      },
      "breadcrumb_level_1_label": {
        "type": "Text",
        "config": {
          "label": "Breadcrumb Level 1 Label"
        }
      },
      "breadcrumb_level_1_href": {
        "type": "Text",
        "config": {
          "label": "Breadcrumb Level 1 Href"
        }
      },
      "breadcrumb_level_2_label": {
        "type": "Text",
        "config": {
          "label": "Breadcrumb Level 2 Label"
        }
      },
      "breadcrumb_level_2_href": {
        "type": "Text",
        "config": {
          "label": "Breadcrumb Level 2 Href"
        }
      },
      "breadcrumb_level_3_label": {
        "type": "Text",
        "config": {
          "label": "Breadcrumb Level 3 Label"
        }
      },
      "breadcrumb_level_3_href": {
        "type": "Text",
        "config": {
          "label": "Breadcrumb Level 3 Href"
        }
      },
      "category_links": {
        "type": "Group",
        "config": {
          "label": "Category Links",
          "repeat": true,
          "fields": {
            "label": {
              "type": "Text",
              "config": {
                "label": "Label"
              }
            },
            "href": {
              "type": "Text",
              "config": {
                "label": "Href"
              }
            }
          }
        }
      },
      "faq_items": {
        "type": "Group",
        "config": {
          "label": "FAQ Items",
          "repeat": true,
          "fields": {
            "question": {
              "type": "Text",
              "config": {
                "label": "Question"
              }
            },
            "answer": {
              "type": "StructuredText",
              "config": {
                "label": "Answer",
                "single": "paragraph,strong,em,hyperlink,list-item,o-list-item"
              }
            },
            "href": {
              "type": "Text",
              "config": {
                "label": "Href"
              }
            }
          }
        }
      },
      "detail_cta_label": {
        "type": "Text",
        "config": {
          "label": "Detail CTA Label"
        }
      },
      "detail_cta_href": {
        "type": "Text",
        "config": {
          "label": "Detail CTA Href"
        }
      }
    }
  }
}
