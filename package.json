{
  "name": "api-next-js",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "prismic:pull": "pnpm --filter prismic-app prismic:pull",
    "prismic:sync-slices": "pnpm --filter prismic-app prismic:sync-slices",
    "prismic:types:generate": "pnpm --filter prismic-app prismic:types:generate",
    "prismic:models:generate": "pnpm --filter prismic-app prismic:models:generate",
    "prismic:seed": "pnpm --filter prismic-app prismic:seed",
    "prismic:seed:dry": "pnpm --filter prismic-app prismic:seed:dry",
    "prismic:validate": "pnpm --filter prismic-app prismic:validate",
    "prismic:check": "pnpm --filter prismic-app prismic:check",
    "dev:passport-scan": "pnpm --filter passport-scan-service dev",
    "dev:web": "pnpm --filter web dev",
    "format": "biome format --write .",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "tsx": "^4.20.3",
    "turbo": "^2.9.18",
    "typescript": "^5.9.3"
  },
  "packageManager": "pnpm@10.12.1"
}
